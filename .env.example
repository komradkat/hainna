# ── Core ────────────────────────────────────────────────────────────────────
DEBUG=True
PRODUCTION=False
SECRET_KEY=django-insecure-dev-key-change-me-in-prod
DATABASE_URL=postgres://hainna_user:hainna_password@db:5432/hainna
ALLOWED_HOSTS=localhost,127.0.0.1,hainna

# ── Security & CSRF ─────────────────────────────────────────────────────────
# Comma-separated list of trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Security Defaults (Production should be True)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Proxy Settings
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=True

# ── Traccar GPS ─────────────────────────────────────────────────────────────
TRACCAR_URL=http://traccar:8082
TRACCAR_USER=admin
TRACCAR_PASSWORD=admin
